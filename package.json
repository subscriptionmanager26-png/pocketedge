{
  "name": "pocketedge-preview",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "auth:push": "bash scripts/push-auth-config.sh",
    "sync:ibkr": "node --env-file=.env scripts/sync-ibkr-instruments.mjs",
    "sync:ibkr:upload": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --upload",
    "sync:ibkr:primary": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --types=Stocks,ETFs --prime-only",
    "sync:ibkr:by-exchange": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --fetch-mode=by-exchange --all-exchanges --types=Stocks,ETFs",
    "sync:ibkr:by-exchange:upload": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --fetch-mode=by-exchange --all-exchanges --types=Stocks,ETFs --upload",
    "sync:ibkr:by-exchange:resume": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --fetch-mode=by-exchange --all-exchanges --types=Stocks,ETFs --upload --resume",
    "sync:ibkr:supplement": "node --env-file=.env scripts/sync-ibkr-instruments.mjs --fetch-mode=by-exchange --exchanges=LSEETF,TRWBUKETF --types=Stocks,ETFs --merge-existing --upload",
    "probe:ibkr-primary": "node scripts/probe-ibkr-primary-listings.mjs",
    "build:ibkr-universe": "node scripts/build-ibkr-universe.mjs",
    "fetch:ibkr-prices": "node scripts/fetch-ibkr-prices.mjs",
    "fetch:ibkr-prices:80k": "node scripts/fetch-ibkr-prices.mjs --initial-only --output=ibkr-prices-80k",
    "retry:ibkr-prices": "node scripts/retry-ibkr-prices.mjs",
    "retry:ibkr-prices:80k": "node scripts/retry-ibkr-prices.mjs --input=data/ibkr-prices-80k.json --output=ibkr-prices-80k --passes=2",
    "retry:ibkr-prices:80k:preflight": "node scripts/retry-ibkr-prices.mjs --input=data/ibkr-prices-80k.json --output=ibkr-prices-80k --passes=3 --preflight-count=2 --preflight-wait-ms=2000 --batch-size=50",
    "fetch:alt-prices": "node scripts/fetch-alt-prices.mjs",
    "fetch:yahoo-prices:ibkr-missing": "node scripts/fetch-yahoo-prices-ibkr-missing.mjs --input=data/ibkr-prices-80k-missing-initial.json",
    "remediate:currency-mismatch-mapping": "node scripts/remediate-currency-mismatch-mapping.mjs",
    "refetch:yahoo-currency-fixes": "node scripts/refetch-yahoo-currency-fixes.mjs --only-mismatch-gt5",
    "join:ibkr-yahoo": "node scripts/join-ibkr-yahoo-prices.mjs",
    "scrub:implausible-yahoo": "node scripts/scrub-implausible-yahoo-prices.mjs",
    "remediate:canada-venue-mapping": "node scripts/remediate-canada-venue-mapping.mjs",
    "refetch:canada-yahoo-prices": "node scripts/refetch-canada-yahoo-prices.mjs",
    "fetch:universe-prices": "node --env-file=.env scripts/run-universe-price-fetch.mjs",
    "fetch:universe-prices:dry": "node --env-file=.env scripts/run-universe-price-fetch.mjs --dry-run --limit=200",
    "upload:yahoo-mappings": "node --env-file=.env scripts/upload-yahoo-mappings.mjs",
    "upload:yahoo-mappings:vercel": "node scripts/upload-yahoo-mappings-via-vercel.mjs --production",
    "build:yahoo-isin-mapping": "node scripts/build-yahoo-isin-mapping.mjs",
    "build:yahoo-isin-mapping:unresolved": "node scripts/build-yahoo-isin-mapping.mjs --input=data/alt-prices-yahoo-misses.json --output-dir=data/yahoo-isin-mapping-unresolved --rps=1 --batch-size=200",
    "build:yahoo-isin-mapping:full": "node scripts/build-yahoo-isin-mapping.mjs --output-dir=data/yahoo-isin-mapping-full --exclude-from=data/yahoo-isin-mapping-unresolved/mapping.json --exclude-status=isin_unresolved --seed-cache-from=data/yahoo-isin-mapping-unresolved/isin-cache.json --rps=1 --batch-size=200",
    "build:yahoo-isin-mapping:retry": "node scripts/build-yahoo-isin-retry-input.mjs && node scripts/build-yahoo-isin-mapping.mjs --input=data/yahoo-isin-retry-input.json --output-dir=data/yahoo-isin-mapping-retry --exclude-from=data/yahoo-isin-mapping-unresolved/mapping.json --exclude-status=isin_unresolved --seed-cache-from=data/yahoo-isin-mapping-full/isin-cache.json --seed-cache-positive-only --refetch --rps=1 --batch-size=200",
    "remediate:yahoo-venue-mapping": "node scripts/remediate-yahoo-venue-mapping.mjs --only-us-mapped",
    "benchmark:yahoo-venue-predict": "node scripts/compare-ibkr-yahoo-venue-predict.mjs",
    "scrape:xetra-isin-symbols": "node scripts/scrape-xetra-isin-symbols.mjs",
    "import:xetra-etf-symbols": "node scripts/import-xetra-etf-symbols.mjs",
    "benchmark:yahoo-xetra-german": "node scripts/compare-ibkr-yahoo-xetra-german.mjs",
    "compare:ibkr-yahoo-full": "node scripts/compare-ibkr-yahoo-full.mjs",
    "compare:ibkr-yahoo-full:resolve": "node scripts/compare-ibkr-yahoo-full.mjs --phase=resolve",
    "benchmark:prices:speed": "node scripts/benchmark-price-gateways.mjs --phase=speed",
    "benchmark:prices:accuracy": "node scripts/benchmark-price-gateways.mjs --phase=accuracy",
    "sync:ucits-info": "python3 scripts/scrape-ucits-info.py",
    "sync:ucits-info:upload": "python3 scripts/scrape-ucits-info.py && python3 scripts/upload-ucits-reference.py",
    "fetch:ucits-screener-sample": "node scripts/fetch-ucits-screener-sample.mjs --limit=100",
    "fetch:ucits-screener": "node scripts/fetch-ucits-screener.mjs",
    "backfill:ucits-aum": "node scripts/backfill-ucits-aum.mjs",
    "backfill:ucits-isin": "node scripts/backfill-ucits-isin.mjs",
    "backfill:ucits-justetf": "node scripts/backfill-ucits-justetf.mjs",
    "normalize:ucits-aum-usd": "node scripts/normalize-ucits-aum-usd.mjs",
    "fetch:basket-prices": "node --env-file=.env scripts/run-basket-price-fetch.mjs",
    "fetch:basket-prices:dry": "node --env-file=.env scripts/run-basket-price-fetch.mjs --dry-run",
    "fetch:basket-nav": "node --env-file=.env scripts/run-basket-nav-update.mjs",
    "fetch:basket-nav:dry": "node --env-file=.env scripts/run-basket-nav-update.mjs --dry-run",
    "remediate:basket-conids": "node --env-file=.env scripts/remediate-basket-conids.mjs",
    "remediate:basket-conids:dry": "node --env-file=.env scripts/remediate-basket-conids.mjs --dry-run",
    "probe:ibkr-preflight-ladder": "node scripts/probe-ibkr-preflight-ladder.mjs",
    "probe:ibkr-preflight-ladder:50": "node scripts/probe-ibkr-preflight-ladder.mjs --sample=50 --batch-size=10",
    "probe:server-ibkr": "node scripts/invoke-server-ibkr-probes.mjs --sample=50",
    "probe:server-yahoo": "node scripts/invoke-server-ibkr-probes.mjs --yahoo --sample=10",
    "simulate:basket-nav": "node scripts/simulate-basket-nav.mjs"
  },
  "dependencies": {
    "@posthog/react": "^1.10.1",
    "@supabase/supabase-js": "^2.49.1",
    "lucide-react": "^0.469.0",
    "posthog-js": "^1.386.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.128.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vercel/functions": "^3.7.2",
    "@vercel/node": "^5.8.17",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3"
  }
}
