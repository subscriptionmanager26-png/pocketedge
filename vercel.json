{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/ibkr-preflight-ladder-probe.ts": {
      "maxDuration": 60
    },
    "api/yahoo-probe.ts": {
      "maxDuration": 60
    },
    "api/cron/universe-price-fetch.ts": {
      "maxDuration": 300
    },
    "api/cron/seed-yahoo-mappings.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
